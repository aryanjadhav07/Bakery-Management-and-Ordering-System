# Copy this file to .env and fill in your values.
# For LOCAL development with SQLite, leave DATABASE_URL and DB_NAME empty.
# For LOCAL development with PostgreSQL, fill in DB_* variables.
# For RENDER deployment, set DATABASE_URL (Render provides this automatically).

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Option A: Render / single connection string ---
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Option B: Individual variables ---
# DB_NAME=bakery_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
